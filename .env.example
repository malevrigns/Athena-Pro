# ------------------------------------------------------------------
# Athena Pro — single-user production .env template
# Copy to `.env` and fill in. All keys default to safe values so the
# product boots even when nothing is configured (mock mode).
# ------------------------------------------------------------------

# Runtime
ATHENA_ENV=prod
ATHENA_LOG_LEVEL=INFO
ATHENA_DATA_DIR=.athena-data

# Single-user auth — bearer token clients must send as `Authorization: Bearer <ATHENA_API_KEY>`.
# Generate something like: python -c "import secrets;print(secrets.token_urlsafe(40))"
ATHENA_REQUIRE_AUTH=true
ATHENA_API_KEY=change-me-to-a-long-random-string

# Allowed CORS origins (comma-separated when set via env).  Browser front-end domain.
ATHENA_ALLOWED_ORIGINS=["http://localhost:5173"]

# LLM provider: mock | openai | anthropic | deepseek | openrouter
ATHENA_LLM_PROVIDER=mock
ATHENA_DEFAULT_MODEL=gpt-4o-mini
# Optional per-node overrides
# ATHENA_PLANNER_MODEL=gpt-4o
# ATHENA_RESEARCHER_MODEL=gpt-4o-mini
# ATHENA_WRITER_MODEL=gpt-4o

# OpenAI / OpenAI-compatible
ATHENA_OPENAI_API_KEY=
# ATHENA_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ATHENA_ANTHROPIC_API_KEY=

# DeepSeek (OpenAI-compatible)
ATHENA_DEEPSEEK_API_KEY=

# OpenRouter (OpenAI-compatible, all models)
ATHENA_OPENROUTER_API_KEY=

# Search provider: mock | tavily
ATHENA_SEARCH_PROVIDER=mock
ATHENA_TAVILY_API_KEY=
ATHENA_SEARCH_MAX_RESULTS=5

# Graph behaviour
ATHENA_MAX_RESEARCH_ITERATIONS=2
ATHENA_QUALITY_THRESHOLD=0.7
ATHENA_MAX_BUDGET_USD=5.0
ATHENA_HARD_TIMEOUT_SEC=600
ATHENA_RATE_LIMIT_PER_MINUTE=30
ATHENA_MAX_UPLOAD_BYTES=26214400
