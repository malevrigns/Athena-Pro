"""管理多个 MCP server 的生命周期 + 统一工具列表"""
from __future__ import annotations
import json
from pathlib import Path

from langchain_core.tools import BaseTool

from athena.config import settings
from athena.mcp.adapter import MCPLangChainTool
from athena.mcp.client import MCPServerConfig, MCPStdioClient
from athena.observability import logger


class MCPManager:
    """单例,管理所有连接的 MCP server。"""
    
    def __init__(self):
        self.clients: dict[str, MCPStdioClient] = {}
        self.tools: list[MCPLangChainTool] = []
    
    @classmethod
    def from_config_file(cls, path: Path | None = None) -> "MCPManager":
        cfg_path = path or Path.home() / ".athena" / "mcp.json"
        if not cfg_path.exists():
            logger.warning("mcp_config_missing", path=str(cfg_path))
            return cls()
        
        raw = json.loads(cfg_path.read_text())
        mgr = cls()
        for name, server_cfg in raw.get("servers", {}).items():
            mgr._add_server(MCPServerConfig(name=name, **server_cfg))
        return mgr
    
    def _add_server(self, cfg: MCPServerConfig) -> None:
        if cfg.transport != "stdio":
            logger.warning("mcp_transport_not_supported", server=cfg.name,
                           transport=cfg.transport)
            return  # SSE 留作练习
        self.clients[cfg.name] = MCPStdioClient(cfg)