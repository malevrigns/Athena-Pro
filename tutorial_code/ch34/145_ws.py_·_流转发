async def _stream_to_ws(websocket: WebSocket, task_id: str,
                        cancel_event: asyncio.Event) -> None:
    """把 graph 流转发到 WebSocket,支持中途取消。"""
    from athena.api.main import _app_state
    config = {"configurable": {"thread_id": task_id}}
    graph = _app_state.graph
    
    try:
        async for chunk in graph.astream(
            None, config=config,
            stream_mode=["updates", "messages"],
        ):
            # 关键:每个 chunk 之间检查取消标志
            if cancel_event.is_set():
                logger.info("ws_stream_cancelled", task_id=task_id)
                return
            
            mode, payload = chunk
            if mode == "updates":
                for node, update in payload.items():
                    await websocket.send_json({
                        "type": "node_update",
                        "task_id": task_id,
                        "node": node,
                        "summary": _summarize_update(update),
                    })
            elif mode == "messages":
                msg_chunk, meta = payload
                if msg_chunk.content:
                    await websocket.send_json({
                        "type": "token",
                        "task_id": task_id,
                        "node": meta.get("langgraph_node"),
                        "content": msg_chunk.content,
                    })
        
        snapshot = await graph.aget_state(config)
        await websocket.send_json({
            "type": "done",
            "task_id": task_id,
            "final_report": snapshot.values.get("final_report"),
        })
    
    except asyncio.CancelledError:
        return
    except Exception as e:
        logger.exception("ws_stream_error", task_id=task_id)
        await websocket.send_json({"type": "error", "error": str(e)})