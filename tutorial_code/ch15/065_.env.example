# 复制为 .env 后填入真实值。.env 务必加到 .gitignore。

ENV=dev

# LLM
LLM_OPENAI_API_KEY=sk-...
LLM_ANTHROPIC_API_KEY=
LLM_PRIMARY_MODEL=gpt-4o-mini
LLM_FALLBACK_MODEL=claude-3-5-haiku-latest

# 数据库
DB_POSTGRES_URL=postgresql://athena:athena@localhost:5432/athena
DB_REDIS_URL=redis://localhost:6379/0

# Graph 行为
GRAPH_MAX_RESEARCH_TOPICS=6
GRAPH_PARALLEL_RESEARCHERS=5
GRAPH_HITL_TIMEOUT_SECONDS=1800

# 成本
COST_MAX_COST_PER_TASK_CNY=1.0

# 可观测性
OBS_LANGSMITH_API_KEY=
OBS_LANGSMITH_PROJECT=athena-prod
OBS_LOG_LEVEL=INFO
OBS_LOG_FORMAT=json