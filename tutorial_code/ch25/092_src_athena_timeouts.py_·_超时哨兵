"""为暂停的任务设置自动恢复哨兵"""
from __future__ import annotations
import asyncio
from typing import Any

from langgraph.types import Command

from athena.observability import logger


async def schedule_interrupt_timeout(
    graph,
    task_id: str,
    deadline_sec: float,
    default_resume: Any,
) -> None:
    """N 秒后,如果任务还在 interrupt 状态,用 default_resume 自动恢复。"""
    await asyncio.sleep(deadline_sec)
    
    config = {"configurable": {"thread_id": task_id}}
    snapshot = await graph.aget_state(config)
    
    # 检查:任务还在等吗?
    if not snapshot.next:
        return                                       # 任务已完成
    
    is_interrupted = "__interrupt__" in (snapshot.tasks[0].interrupts if snapshot.tasks else [])
    if not is_interrupted:
        return                                       # 不在 interrupt 状态(可能用户已经回应)
    
    logger.warning(
        "interrupt_timeout_triggered",
        task_id=task_id,
        default_resume=default_resume,
    )
    
    # 强制 resume
    await graph.ainvoke(Command(resume=default_resume), config=config)