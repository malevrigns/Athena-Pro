"""带重试 + 降级 + 成本追踪的 LLM 工厂"""
from __future__ import annotations
import openai
from langchain_anthropic import ChatAnthropic
from langchain_openai import ChatOpenAI
from langchain_core.runnables import Runnable

from athena.config import settings
from athena.costs import CostTrackingCallback
from athena.observability import logger


# 已知"值得重试"的异常类型
RETRYABLE_EXCEPTIONS = (
    openai.RateLimitError,
    openai.APITimeoutError,
    openai.InternalServerError,
    openai.APIConnectionError,
)


def get_llm(
    model: str | None = None,
    temperature: float = 0,
    node_name: str = "unknown",
    enable_fallback: bool = True,
    **kwargs,
) -> Runnable:
    """构造带重试 + 降级 + 成本追踪的 LLM。"""
    
    callbacks = [CostTrackingCallback(node_name=node_name)]
    
    primary = ChatOpenAI(
        model=model or settings.default_model,
        temperature=temperature,
        callbacks=callbacks,
        max_retries=0,                                # 关掉自带 retry,我们外层接管
        request_timeout=60,
        **kwargs,
    )
    
    # 加重试:指数退避,最多 3 次
    primary_with_retry = primary.with_retry(
        retry_if_exception_type=RETRYABLE_EXCEPTIONS,
        stop_after_attempt=3,
        wait_exponential_jitter=True,
    )
    
    if not enable_fallback:
        return primary_with_retry
    
    # 降级链: gpt-4o-mini -> gpt-3.5-turbo -> claude-haiku
    fallback_1 = ChatOpenAI(
        model="gpt-3.5-turbo",
        temperature=temperature,
        callbacks=callbacks,
    ).with_retry(retry_if_exception_type=RETRYABLE_EXCEPTIONS, stop_after_attempt=2)
    
    fallback_2 = ChatAnthropic(
        model="claude-3-haiku-20240307",
        temperature=temperature,
        callbacks=callbacks,
    ) if settings.anthropic_api_key else None
    
    fallbacks = [fallback_1]
    if fallback_2:
        fallbacks.append(fallback_2)
    
    return primary_with_retry.with_fallbacks(
        fallbacks,
        exceptions_to_handle=RETRYABLE_EXCEPTIONS + (openai.APIError,),
    )