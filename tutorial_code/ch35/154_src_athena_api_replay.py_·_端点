"""Task 回放 · 让用户看到任务完整执行历史 + 接续实时流"""
from __future__ import annotations
import json
from fastapi import APIRouter, HTTPException
from fastapi.responses import StreamingResponse

from athena.api.streaming import _format_sse, _summarize_update

router = APIRouter()


@router.get("/v1/tasks/{task_id}/replay")
async def replay_task(task_id: str):
    """
    回放:
      1) 从 Postgres checkpoint 历史里读出每一步的快照
      2) 按时间顺序推送给前端(用 SSE)
      3) 如果任务还在跑,接上实时流
    """
    from athena.api.main import _app_state
    graph = _app_state.graph
    
    config = {"configurable": {"thread_id": task_id}}
    
    # 检查任务是否存在
    snapshot = await graph.aget_state(config)
    if not snapshot.values:
        raise HTTPException(404)
    
    return StreamingResponse(
        _replay_stream(graph, config),
        media_type="text/event-stream",
    )